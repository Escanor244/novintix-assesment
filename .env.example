# Healthcare Agentic AI System — Environment Configuration

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Orchestrator
CONFIDENCE_THRESHOLD=0.7

# Note: This prototype uses rule-based agents and does not require
# any LLM API keys. In production, add your LLM provider keys here:
# OPENAI_API_KEY=your-key-here
GOOGLE_API_KEY=your-key-here

# LLM (optional)
LLM_ENABLED=false
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434
LLM_TIMEOUT_SECONDS=8